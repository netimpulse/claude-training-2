{%- liquid
  assign layout = section.settings.layout | default: 'image-left'
  assign image_height = section.settings.image_height | default: 'medium'
-%}

<section
  class="iwt color-{{ section.settings.color_scheme }} iwt--{{ layout }} iwt--height-{{ image_height }}"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="iwt__inner page-width">
    <div class="iwt__media">
      {%- if section.settings.image != blank -%}
        {%- assign img_alt = section.settings.image.alt | default: section.settings.heading | default: '' | escape -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '360, 540, 720, 900, 1200, 1500',
            sizes: '(min-width: 990px) 50vw, 100vw',
            class: 'iwt__image',
            alt: img_alt
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'iwt__image iwt__image--placeholder' }}
      {%- endif -%}
    </div>

    <div class="iwt__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            <p class="iwt__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</p>
          {%- when 'heading' -%}
            <h2 class="iwt__heading" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</h2>
          {%- when 'text' -%}
            <div class="iwt__text rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}
            {%- if block.settings.label != blank and block.settings.url != blank -%}
              <div class="iwt__btn-wrap" {{ block.shopify_attributes }}>
                <a
                  class="btn btn--{{ block.settings.style | default: 'primary' }}"
                  href="{{ block.settings.url }}"
                >
                  {{ block.settings.label | escape }}
                </a>
              </div>
            {%- endif -%}
          {%- when 'feature_list' -%}
            <ul class="iwt__features" {{ block.shopify_attributes }}>
              {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
              {%- for item in items -%}
                {%- assign trimmed = item | strip -%}
                {%- if trimmed != blank -%}
                  <li>
                    <span class="iwt__feature-icon" aria-hidden="true">
                      {%- render 'icon', name: 'check' -%}
                    </span>
                    <span>{{ trimmed }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "t:sections.image_with_text.name",
  "tag": "section",
  "class": "section-iwt",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:shared.image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.image_with_text.layout",
      "options": [
        { "value": "image-left", "label": "t:sections.image_with_text.image_left" },
        { "value": "image-right", "label": "t:sections.image_with_text.image_right" }
      ],
      "default": "image-left"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "t:sections.image_with_text.image_height",
      "options": [
        { "value": "small", "label": "t:shared.height_small" },
        { "value": "medium", "label": "t:shared.height_medium" },
        { "value": "large", "label": "t:shared.height_large" }
      ],
      "default": "medium"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:shared.accessibility_heading",
      "info": "t:sections.image_with_text.heading_info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:shared.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:shared.section_padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:shared.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:shared.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "t:sections.image_with_text.block_eyebrow",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:shared.text",
          "default": "About us"
        }
      ]
    },
    {
      "type": "heading",
      "name": "t:sections.image_with_text.block_heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:shared.text",
          "default": "Designed for everyday confidence"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.image_with_text.block_text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "t:shared.text",
          "default": "<p>Tell your brand story, highlight values, or share the details that matter most about a collection or product.</p>"
        }
      ]
    },
    {
      "type": "feature_list",
      "name": "t:sections.image_with_text.block_features",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "items",
          "label": "t:sections.image_with_text.features_info",
          "default": "Made in Europe\nOrganic cotton\nCarbon-neutral shipping"
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.image_with_text.block_button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:shared.label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:shared.link_url"
        },
        {
          "type": "select",
          "id": "style",
          "label": "t:shared.button_style",
          "options": [
            { "value": "primary", "label": "t:shared.button_primary" },
            { "value": "secondary", "label": "t:shared.button_secondary" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_with_text.name",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
