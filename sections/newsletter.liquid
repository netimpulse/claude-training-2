{%- liquid
  assign has_bg_image = false
  if section.settings.background_image != blank
    assign has_bg_image = true
  endif
  assign alignment = section.settings.alignment | default: 'center'
-%}

<section
  class="newsletter color-{{ section.settings.color_scheme }} newsletter--{{ alignment }}{% if has_bg_image %} newsletter--has-image{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  {%- if has_bg_image -%}
    <div class="newsletter__bg" aria-hidden="true">
      {%- assign bg_alt = section.settings.background_image.alt | default: '' | escape -%}
      {{
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '720, 1080, 1440, 1800, 2400',
          sizes: '100vw',
          class: 'newsletter__bg-image',
          alt: bg_alt
      }}
      <div class="newsletter__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- endif -%}

  <div class="newsletter__inner page-width">
    <div class="newsletter__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="newsletter__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="newsletter__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- form 'customer', id: 'NewsletterForm', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__field">
          <label for="NewsletterEmail-{{ section.id }}" class="visually-hidden">
            {{ 'newsletter.label_email' | t }}
          </label>
          <input
            type="email"
            id="NewsletterEmail-{{ section.id }}"
            name="contact[email]"
            placeholder="{{ 'newsletter.placeholder_email' | t }}"
            required
            autocomplete="email"
            aria-required="true"
            class="newsletter__input"
          >
          <button type="submit" class="newsletter__submit btn btn--primary" name="commit">
            <span>{{ 'newsletter.submit' | t }}</span>
            <span class="newsletter__submit-icon" aria-hidden="true">
              {%- render 'icon', name: 'arrow-right' -%}
            </span>
          </button>
        </div>

        {%- if form.errors -%}
          <p class="newsletter__feedback newsletter__feedback--error">
            {{ form.errors | default_errors }}
          </p>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <p class="newsletter__feedback newsletter__feedback--success">
            {{ 'newsletter.success' | t }}
          </p>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.legal_text != blank -%}
        <p class="newsletter__legal">{{ section.settings.legal_text }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:shared.eyebrow",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:shared.heading",
      "default": "Be the first to know"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:shared.text",
      "default": "<p>Get 10% off your first order and early access to new drops.</p>"
    },
    {
      "type": "richtext",
      "id": "legal_text",
      "label": "t:sections.newsletter.legal_text"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:shared.alignment",
      "options": [
        { "value": "left", "label": "t:shared.align_left" },
        { "value": "center", "label": "t:shared.align_center" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.newsletter.background_image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.newsletter.overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:shared.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:shared.section_padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:shared.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:shared.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
