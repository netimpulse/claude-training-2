{%- comment -%}
  Hero section — two modes:
    - slideshow: image slides with optional autoplay, caption overlay, CTAs
    - video: self-hosted Shopify video or external video (YouTube/Vimeo), can autoplay muted in loop, or act as background

  Blocks are used for slides so merchants can add/remove/reorder.
  In video mode, blocks are not rendered — instead the section uses the single `video` setting.
{%- endcomment -%}

{{ 'section-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-hero.js' | asset_url }}" defer></script>

{%- liquid
  assign scheme = section.settings.color_scheme
  assign mode = section.settings.mode
  assign height = section.settings.height
  assign content_align = section.settings.content_align
  assign overlay_opacity = section.settings.overlay_opacity | default: 0
-%}

{% style %}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} .hero {
    --hero-overlay: {{ overlay_opacity | divided_by: 100.0 }};
    --hero-min-height: {% case height %}{% when 'small' %}45vh{% when 'medium' %}65vh{% when 'large' %}85vh{% when 'full' %}100vh{% else %}65vh{% endcase %};
  }
{% endstyle %}

<div class="hero hero--{{ mode }} hero--align-{{ content_align }} color-scheme color-{{ scheme.id }}"
     data-section-id="{{ section.id }}"
     data-autoplay="{{ section.settings.autoplay }}"
     data-autoplay-speed="{{ section.settings.autoplay_speed | default: 5 }}">
  {%- case mode -%}

  {%- when 'slideshow' -%}
    {%- if section.blocks.size > 0 -%}
      <hero-slideshow class="hero__slideshow">
        <div class="hero__slides" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'slide' -%}
              {%- liquid
                assign slide_heading = block.settings.heading
                assign slide_subheading = block.settings.subheading
                assign slide_btn_label = block.settings.button_label
                assign slide_btn_link = block.settings.button_link
                assign slide_btn2_label = block.settings.button_label_2
                assign slide_btn2_link = block.settings.button_link_2
                assign slide_image_alt = block.settings.image.alt | default: slide_heading | default: shop.name | escape
                assign img_loading = 'lazy'
                assign img_fetchpriority = 'auto'
                if forloop.first
                  assign img_loading = 'eager'
                  assign img_fetchpriority = 'high'
                endif
              -%}
              <div class="hero__slide{% if forloop.first %} hero__slide--active{% endif %}"
                   role="listitem"
                   aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                   data-slide-index="{{ forloop.index0 }}"
                   {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 2000 | image_tag:
                     alt: slide_image_alt,
                     class: 'hero__media',
                     loading: img_loading,
                     fetchpriority: img_fetchpriority,
                     widths: '400,600,900,1200,1600,2000',
                     sizes: '100vw' }}
                {%- else -%}
                  <div class="hero__placeholder">
                    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media hero__placeholder-svg' }}
                  </div>
                {%- endif -%}

                {%- if overlay_opacity > 0 -%}
                  <span class="hero__overlay" aria-hidden="true"></span>
                {%- endif -%}

                {%- if slide_heading != blank or slide_subheading != blank or slide_btn_label != blank or slide_btn2_label != blank -%}
                  <div class="hero__content">
                    <div class="hero__content-inner">
                      {%- if block.settings.eyebrow != blank -%}
                        <span class="eyebrow">{{ block.settings.eyebrow | escape }}</span>
                      {%- endif -%}
                      {%- if slide_heading != blank -%}
                        <h2 class="hero__heading">{{ slide_heading | escape }}</h2>
                      {%- endif -%}
                      {%- if slide_subheading != blank -%}
                        <div class="hero__subheading">{{ slide_subheading }}</div>
                      {%- endif -%}
                      {%- if slide_btn_label != blank or slide_btn2_label != blank -%}
                        <div class="hero__cta-row">
                          {%- if slide_btn_label != blank -%}
                            <a href="{{ slide_btn_link | default: '#' }}" class="btn btn--primary">{{ slide_btn_label | escape }}</a>
                          {%- endif -%}
                          {%- if slide_btn2_label != blank -%}
                            <a href="{{ slide_btn2_link | default: '#' }}" class="btn btn--secondary">{{ slide_btn2_label | escape }}</a>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 1 -%}
          <div class="hero__controls">
            <button type="button" class="hero__arrow hero__arrow--prev" aria-label="{{ 'general.slideshow.previous' | t }}">
              {%- render 'icon', name: 'chevron-left' -%}
            </button>
            <div class="hero__dots" role="tablist" aria-label="{{ 'general.slideshow.dots' | t }}">
              {%- for block in section.blocks -%}
                <button type="button"
                        class="hero__dot{% if forloop.first %} hero__dot--active{% endif %}"
                        role="tab"
                        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                        aria-label="{{ 'general.slideshow.go_to' | t }} {{ forloop.index }}"
                        data-dot-index="{{ forloop.index0 }}"></button>
              {%- endfor -%}
            </div>
            <button type="button" class="hero__arrow hero__arrow--next" aria-label="{{ 'general.slideshow.next' | t }}">
              {%- render 'icon', name: 'chevron-right' -%}
            </button>
          </div>
        {%- endif -%}
      </hero-slideshow>
    {%- else -%}
      {%- comment -%} Empty state — visible in theme editor {%- endcomment -%}
      <div class="hero__empty">
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
        <div class="hero__content">
          <div class="hero__content-inner">
            <h2 class="hero__heading">{{ 'sections.hero.empty_heading' | t }}</h2>
            <p>{{ 'sections.hero.empty_text' | t }}</p>
          </div>
        </div>
      </div>
    {%- endif -%}

  {%- when 'video' -%}
    <div class="hero__video-wrap">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag:
           image_size: '2000x',
           autoplay: true,
           muted: true,
           loop: true,
           controls: section.settings.video_controls,
           class: 'hero__video' }}
      {%- elsif section.settings.video_url != blank -%}
        {%- assign video_host = section.settings.video_url.type -%}
        {%- if video_host == 'youtube' -%}
          <iframe class="hero__video hero__video--iframe"
                  src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls={% if section.settings.video_controls %}1{% else %}0{% endif %}&showinfo=0&rel=0&modestbranding=1&playsinline=1"
                  title="{{ 'sections.hero.video_title' | t }}"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  loading="lazy"
                  frameborder="0"></iframe>
        {%- elsif video_host == 'vimeo' -%}
          <iframe class="hero__video hero__video--iframe"
                  src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background={% unless section.settings.video_controls %}1{% endunless %}"
                  title="{{ 'sections.hero.video_title' | t }}"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  loading="lazy"
                  frameborder="0"></iframe>
        {%- endif -%}
      {%- else -%}
        {%- if section.settings.fallback_image != blank -%}
          {%- assign fb_alt = section.settings.fallback_image.alt | default: shop.name | escape -%}
          {{ section.settings.fallback_image | image_url: width: 2000 | image_tag:
             alt: fb_alt,
             class: 'hero__video',
             loading: 'eager',
             sizes: '100vw',
             widths: '600,900,1200,1600,2000' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__video' }}
        {%- endif -%}
      {%- endif -%}

      {%- if overlay_opacity > 0 -%}
        <span class="hero__overlay" aria-hidden="true"></span>
      {%- endif -%}

      {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
        <div class="hero__content">
          <div class="hero__content-inner">
            {%- if section.settings.eyebrow != blank -%}
              <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="hero__heading">{{ section.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.subheading != blank -%}
              <div class="hero__subheading">{{ section.settings.subheading }}</div>
            {%- endif -%}
            {%- if section.settings.button_label != blank -%}
              <div class="hero__cta-row">
                <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--primary">{{ section.settings.button_label | escape }}</a>
                {%- if section.settings.button_label_2 != blank -%}
                  <a href="{{ section.settings.button_link_2 | default: '#' }}" class="btn btn--secondary">{{ section.settings.button_label_2 | escape }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endcase -%}
</div>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.hero.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "t:sections.hero.settings.mode.label",
      "options": [
        { "value": "slideshow", "label": "t:sections.hero.settings.mode.options__slideshow.label" },
        { "value": "video", "label": "t:sections.hero.settings.mode.options__video.label" }
      ],
      "default": "slideshow"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.hero.settings.height.label",
      "options": [
        { "value": "small", "label": "t:sections.hero.settings.height.options__small.label" },
        { "value": "medium", "label": "t:sections.hero.settings.height.options__medium.label" },
        { "value": "large", "label": "t:sections.hero.settings.height.options__large.label" },
        { "value": "full", "label": "t:sections.hero.settings.height.options__full.label" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "t:sections.hero.settings.content_align.label",
      "options": [
        { "value": "left", "label": "t:sections.hero.settings.content_align.options__left.label" },
        { "value": "center", "label": "t:sections.hero.settings.content_align.options__center.label" },
        { "value": "right", "label": "t:sections.hero.settings.content_align.options__right.label" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.hero.settings.overlay_opacity.label",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.slideshow_header.content",
      "info": "t:sections.hero.settings.slideshow_header.info"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.hero.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.hero.settings.autoplay_speed.label",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.video_header.content",
      "info": "t:sections.hero.settings.video_header.info"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.hero.settings.video.label"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:sections.hero.settings.video_url.label",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "t:sections.hero.settings.video_controls.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "t:sections.hero.settings.fallback_image.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.settings.heading.label",
      "default": "New Collection"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.hero.settings.subheading.label",
      "default": "<p>Discover the latest pieces.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.hero.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.hero.settings.button_link.label"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "t:sections.hero.settings.button_label_2.label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "t:sections.hero.settings.button_link_2.label"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.hero.blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.hero.blocks.slide.settings.image.label"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:sections.hero.blocks.slide.settings.eyebrow.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.hero.blocks.slide.settings.heading.label",
          "default": "Spring Drop"
        },
        {
          "type": "richtext",
          "id": "subheading",
          "label": "t:sections.hero.blocks.slide.settings.subheading.label",
          "default": "<p>Elevate your wardrobe.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.hero.blocks.slide.settings.button_label.label",
          "default": "Shop collection"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.hero.blocks.slide.settings.button_link.label"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "t:sections.hero.blocks.slide.settings.button_label_2.label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "t:sections.hero.blocks.slide.settings.button_link_2.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.presets.name",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
