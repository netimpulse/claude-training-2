{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: 2
  assign image_ratio = section.settings.image_ratio | default: 'portrait'
  assign show_vendor = section.settings.show_vendor
  assign show_view_all = section.settings.show_view_all
-%}

<section
  class="featured-collection color-{{ section.settings.color_scheme }}"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --fc-cols-desktop: {{ columns_desktop }}; --fc-cols-mobile: {{ columns_mobile }};"
>
  <div class="featured-collection__inner page-width">
    <header class="featured-collection__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="featured-collection__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="featured-collection__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="featured-collection__subheading rte">{{ section.settings.subheading }}</div>
      {%- endif -%}
    </header>

    {%- if collection != blank and collection.products.size > 0 -%}
      <ul class="featured-collection__grid" role="list">
        {%- for product in collection.products limit: products_to_show -%}
          <li class="featured-collection__item">
            {%- render 'product-card', product: product, show_vendor: show_vendor, image_ratio: image_ratio, lazy: true -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_view_all and collection.url != blank -%}
        <div class="featured-collection__footer">
          <a class="btn btn--secondary" href="{{ collection.url }}">
            {{ 'sections.featured_collection.view_all' | t }}
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <ul class="featured-collection__grid" role="list">
        {%- for i in (1..products_to_show) -%}
          <li class="featured-collection__item">
            <div class="product-card product-card--{{ image_ratio }}">
              <div class="product-card__media">
                {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__image--placeholder' }}
              </div>
              <div class="product-card__info">
                <h3 class="product-card__title">{{ 'products.placeholder_title' | t }}</h3>
                <p class="product-card__price">{{ 1999 | money }}</p>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:shared.eyebrow",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:shared.heading",
      "default": "Featured collection"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:shared.subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.featured_collection.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "t:sections.featured_collection.columns_mobile",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.featured_collection.image_ratio",
      "options": [
        { "value": "portrait", "label": "t:sections.featured_collection.image_ratio_portrait" },
        { "value": "square", "label": "t:sections.featured_collection.image_ratio_square" },
        { "value": "landscape", "label": "t:sections.featured_collection.image_ratio_landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.featured_collection.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.featured_collection.show_view_all",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:shared.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:shared.section_padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:shared.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:shared.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
