{%- comment -%}
  Footer section — fashion brand
  Features:
    - Block-based: merchant adds menu blocks, text blocks, newsletter block
    - Automatic Shopify policy links (AGB, Datenschutz, Versand, Impressum, Widerrufsrecht)
       via shop.policies — pulled directly from Shopify store settings
    - Social media icons from global theme settings
    - Payment icons (optional)
    - Copyright line with dynamic year
{%- endcomment -%}

{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign scheme = section.settings.color_scheme
  assign show_policies = section.settings.show_policies
  assign show_socials = section.settings.show_socials
  assign show_payment_icons = section.settings.show_payment_icons
  assign current_year = 'now' | date: '%Y'
-%}

{% style %}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} {
    --footer-padding-top: {{ section.settings.padding_top }}px;
    --footer-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="site-footer color-scheme color-{{ scheme.id }}">
  <div class="site-footer__inner">
    {%- if section.settings.heading != blank -%}
      <div class="site-footer__heading-wrap">
        <h2 class="site-footer__heading">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="site-footer__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="site-footer__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'logo_info' -%}
              <div class="site-footer__col site-footer__col--brand" {{ block.shopify_attributes }}>
                {%- if block.settings.logo != blank -%}
                  {%- assign footer_logo_alt = block.settings.logo.alt | default: shop.name | escape -%}
                  {%- assign footer_logo_w = block.settings.logo_height | times: 4 -%}
                  {{ block.settings.logo | image_url: width: footer_logo_w | image_tag:
                     alt: footer_logo_alt,
                     loading: 'lazy',
                     class: 'site-footer__logo',
                     widths: '120,240,360',
                     sizes: '180px' }}
                {%- else -%}
                  <p class="site-footer__brand-name">{{ shop.name }}</p>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="site-footer__description">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if show_socials -%}
                  {%- render 'footer-socials' -%}
                {%- endif -%}
              </div>

            {%- when 'menu' -%}
              <div class="site-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="site-footer__col-heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- assign footer_linklist = linklists[block.settings.menu] -%}
                {%- if footer_linklist.links.size > 0 -%}
                  <ul class="site-footer__list" role="list">
                    {%- for link in footer_linklist.links -%}
                      <li><a href="{{ link.url }}" class="site-footer__link">{{ link.title | escape }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'text' -%}
              <div class="site-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="site-footer__col-heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="site-footer__richtext rte">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>

            {%- when 'newsletter' -%}
              <div class="site-footer__col site-footer__col--newsletter" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="site-footer__col-heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="site-footer__newsletter-desc">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- form 'customer', id: 'FooterNewsletter', class: 'site-footer__newsletter-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <label for="FooterNewsletterEmail" class="visually-hidden">{{ 'newsletter.email_label' | t }}</label>
                  <div class="site-footer__newsletter-field">
                    <input id="FooterNewsletterEmail"
                           type="email"
                           name="contact[email]"
                           class="site-footer__newsletter-input"
                           placeholder="{{ 'newsletter.email_placeholder' | t }}"
                           autocomplete="email"
                           required>
                    <button type="submit" class="site-footer__newsletter-submit" aria-label="{{ 'newsletter.submit' | t }}">
                      {%- render 'icon', name: 'arrow-right' -%}
                    </button>
                  </div>
                  {%- if form.posted_successfully? -%}
                    <p class="site-footer__newsletter-success">{{ 'newsletter.success' | t }}</p>
                  {%- endif -%}
                  {%- if form.errors -%}
                    <p class="site-footer__newsletter-error">{{ form.errors.messages.email }}</p>
                  {%- endif -%}
                {%- endform -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="site-footer__bottom">
      <p class="site-footer__copy">&copy; {{ current_year }} {{ shop.name }}. {{ 'general.footer.copyright_suffix' | t }}</p>

      {%- comment -%} ======= SHOPIFY POLICIES (AGB, Datenschutz, Versand, Widerruf, Impressum) ======= {%- endcomment -%}
      {%- if show_policies and shop.policies.size > 0 -%}
        <ul class="site-footer__policies" role="list" aria-label="{{ 'general.footer.policies' | t }}">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li><a href="{{ policy.url }}" class="site-footer__policy-link">{{ policy.title | escape }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if show_payment_icons and shop.enabled_payment_types.size > 0 -%}
        <ul class="site-footer__payment" role="list" aria-label="{{ 'general.footer.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "footer",
  "class": "section-site-footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.footer.settings.color_scheme.label",
      "default": "scheme-3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.footer.settings.heading.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.footer.settings.subheading.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.policies_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "t:sections.footer.settings.show_policies.label",
      "info": "t:sections.footer.settings.show_policies.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "t:sections.footer.settings.show_socials.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.padding_header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_top.label",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_bottom.label",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "logo_info",
      "name": "t:sections.footer.blocks.logo_info.name",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:sections.footer.blocks.logo_info.settings.logo.label"
        },
        {
          "type": "range",
          "id": "logo_height",
          "min": 20,
          "max": 80,
          "step": 4,
          "unit": "px",
          "label": "t:sections.footer.blocks.logo_info.settings.logo_height.label",
          "default": 40
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "t:sections.footer.blocks.logo_info.settings.description.label",
          "default": "<p>A short description of your brand.</p>"
        }
      ]
    },
    {
      "type": "menu",
      "name": "t:sections.footer.blocks.menu.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.menu.settings.heading.label",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.menu.settings.menu.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label",
          "default": "About"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.footer.blocks.text.settings.content.label",
          "default": "<p>Share more information about your brand.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.newsletter.settings.heading.label",
          "default": "Newsletter"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "t:sections.footer.blocks.newsletter.settings.description.label",
          "default": "<p>Sign up for exclusive drops and offers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.footer.presets.name",
      "blocks": [
        { "type": "logo_info" },
        { "type": "menu" },
        { "type": "menu" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
